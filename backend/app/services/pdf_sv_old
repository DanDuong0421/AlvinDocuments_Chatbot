import os
import pypdf
import uuid
import pandas as pd
from docx import Document as DocxDocument
from fastapi import UploadFile, HTTPException
from app.core.lifespan import models_cache 
from qdrant_client import QdrantClient, models

# --- HÀM TRÍCH XUẤT CẢI TIẾN ĐỂ GIỮ NGỮ CẢNH ---

def extract_chunks_from_pdf(file_path: str, text_splitter, file_name: str):
    """Gộp toàn bộ text và chia nhỏ có overlap để không mất ngữ cảnh giữa các trang"""
    reader = pypdf.PdfReader(file_path)
    full_text_with_marks = ""
    
    # Bước 1: Gộp text kèm đánh dấu trang ẩn
    for page_num, page in enumerate(reader.pages):
        page_text = page.extract_text() or ""
        # Chèn dấu mốc trang để sau này AI vẫn biết thông tin nằm ở đâu
        full_text_with_marks += f"\n[PAGE_{page_num + 1}]\n{page_text}"

    # Bước 2: Chia nhỏ toàn bộ văn bản (giúp giữ liên kết giữa các trang)
    chunks = text_splitter.split_text(full_text_with_marks)
    
    chunks_with_metadata = []
    current_page = 1
    
    for chunk in chunks:
        # Tìm xem mảnh này thuộc trang nào dựa vào dấu mốc gần nhất
        if "[PAGE_" in chunk:
            try:
                # Cập nhật số trang nếu tìm thấy dấu mốc trong chunk
                current_page = int(chunk.split("[PAGE_")[1].split("]")[0])
            except:
                pass
        
        # Làm sạch chunk (xóa dấu mốc trang để AI đọc không bị rối)
        clean_content = chunk.split("]\n")[-1] if "]\n" in chunk else chunk
        
        chunks_with_metadata.append({
            "content": clean_content,
            "metadata": {"source": file_name, "page": current_page}
        })
        
    return chunks_with_metadata

# --- CÁC HÀM CÒN LẠI GIỮ NGUYÊN ---

def extract_chunks_from_docx(file_path: str, text_splitter, file_name: str):
    doc = DocxDocument(file_path)
    full_text = "\n".join([para.text for para in doc.paragraphs])
    chunks = text_splitter.split_text(full_text)
    return [{"content": c, "metadata": {"source": file_name, "page": "N/A"}} for c in chunks]

def index_document_file(file: UploadFile, temp_file_path: str) -> str:
    file_extension = os.path.splitext(file.filename)[1].lower()
    
    embedding_model = models_cache["embedding_model"]
    qdrant_client: QdrantClient = models_cache["qdrant_client"]
    text_splitter = models_cache["text_splitter"]

    try:
        if file_extension == ".pdf":
            data_to_index = extract_chunks_from_pdf(temp_file_path, text_splitter, file.filename)
        elif file_extension in [".docx", ".doc"]:
            data_to_index = extract_chunks_from_docx(temp_file_path, text_splitter, file.filename)
        elif file_extension == ".txt":
            with open(temp_file_path, "r", encoding="utf-8") as f:
                txt = f.read()
            data_to_index = [{"content": c, "metadata": {"source": file.filename, "page": "N/A"}} for c in text_splitter.split_text(txt)]
        elif file_extension in [".xlsx", ".xls"]:
            df = pd.read_excel(temp_file_path)
            data_to_index = [{"content": df.to_string(), "metadata": {"source": file.filename, "page": "Excel"}}]
        else:
            raise HTTPException(status_code=400, detail=f"Định dạng {file_extension} chưa được hỗ trợ.")
        
        if not data_to_index:
            raise HTTPException(status_code=400, detail="File không có nội dung text.")
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Lỗi đọc file: {str(e)}")

    collection_name = f"doc_{uuid.uuid4().hex}"
    qdrant_client.recreate_collection(
        collection_name=collection_name,
        vectors_config=models.VectorParams(size=1024, distance=models.Distance.COSINE),
    )

    points = []
    for i, item in enumerate(data_to_index):
        vector = embedding_model.encode("passage: " + item["content"]).tolist()
        points.append(models.PointStruct(
            id=i,
            vector=vector,
            payload={
                "content": item["content"], 
                "source": item["metadata"]["source"],
                "page": item["metadata"]["page"] 
            }
        ))
    
    qdrant_client.upsert(collection_name=collection_name, points=points)
    models_cache["last_collection"] = collection_name

    return collection_name